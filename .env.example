# Porta do servidor (Railway define PORT automaticamente)
PORT=3000

# Carteira Base que vai receber os pagamentos em USDC
PAY_TO_ADDRESS=0xb1DF24c41607d6cC8b34a47f8b4E4F4A3bCe4533

# URL do facilitator x402 responsável por validar/liquidar os pagamentos on-chain.
# Para produção na mainnet Base, use um facilitator que suporte eip155:8453.
# Exemplo (Coinbase CDP): https://api.cdp.coinbase.com/platform/v2/x402
# Exemplo (teste/dev):    https://x402.org/facilitator
X402_FACILITATOR_URL=https://x402.org/facilitator

# Preço cobrado por consulta (em dólares, convertido para USDC pelo protocolo)
PRICE_PER_QUERY=$0.05
